<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- All optional Blazing.Mediator source-gen features are OFF for this baseline -->
    <!-- USE_SOURCE_GENERATORS is intentionally NOT defined here; the library dispatch  -->
    <!-- path is reflection-based in this initial pre-optimisation benchmark run.       -->

    <!-- Emit source-generated files to a visible folder for inspection -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
    <NoWarn>$(NoWarn);NETSDK1057;NU1608;CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.15.6" />
    <PackageReference Include="BenchmarkDotNet.Diagnostics.Windows" Version="0.15.6" />
    <PackageReference Include="MediatR" Version="12.5.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Blazing.Mediator runtime library (includes its source generator transitively) -->
    <ProjectReference Include="..\..\src\Blazing.Mediator\Blazing.Mediator.csproj" />

	  <!-- Explicitly reference the Blazing.Mediator source generator as an Analyzer -->
    <ProjectReference Include="..\..\src\Blazing.Mediator.SourceGenerators\Blazing.Mediator.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />

    <!-- martinothamar/Mediator runtime library -->
    <PackageReference Include="Mediator.Abstractions" Version="2.1.7" />

    <!-- martinothamar/Mediator source generator as an Analyzer -->
    <PackageReference Include="Mediator.SourceGenerator" Version="2.1.7"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
